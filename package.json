{
  "name": "paper-plane-workspace",
  "version": "1.0.0",
  "description": "Root workspace configuration for Paper Plane AI Greeting Card Generator",
  "private": true,
  "scripts": {
    "install-server": "npm install --prefix server",
    "install-client": "npm install --prefix client",
    "postinstall": "npm run install-server && npm run install-client",
    "dev-server": "npm run dev --prefix server",
    "dev-client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run dev-server\" \"npm run dev-client\"",
    "start": "concurrently \"npm run dev-server\" \"npm run dev-client\""
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
